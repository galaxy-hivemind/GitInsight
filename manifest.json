{
  "manifest_version": 3,
  "name": "GitInsight",
  "version": "1.0.0",
  "description": "Transform GitHub commit history into interactive visual storytelling – timelines, heatmaps, contributor graphs, and repo replay.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "dashboard.js",
        "styles/dashboard.css",
        "lib/d3.min.js",
        "lib/chart.min.js",
        "modules/github-api.js",
        "modules/commit-parser.js",
        "modules/cache.js",
        "modules/insights.js",
        "visualizations/timeline.js",
        "visualizations/heatmap.js",
        "visualizations/contributors.js",
        "visualizations/evolution.js",
        "visualizations/replay.js"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "GitInsight – Repository Visualization",
    "default_popup": "popup.html"
  }
}